        "import time\n",
        "import json\n",
        "import pandas as pd\n",
        "\n",
        "from tqdm import tqdm\n",
        "BATCH_SIZE = 10\n",
        "\n",
        "predictions = []\n",
        "\n",
        "tickets = df[\"ticket_text\"].tolist()\n",
        "\n",
        "ticket_ids = df[\"ticket_id\"].tolist()\n",
        "\n",
        "print(\"\\nStarting Batch Classification...\\n\")\n",
        "\n",
        "for i in tqdm(\n",
        "    range(0, len(tickets), BATCH_SIZE),\n",
        "    desc=\"Classifying Batches\"\n",
        "):\n",
        "\n",
        "    batch_tickets = tickets[i:i+BATCH_SIZE]\n",
        "\n",
        "    batch_ids = ticket_ids[i:i+BATCH_SIZE]\n",
        "\n",
        "    try:\n",
        "\n",
        "        results = classify_ticket_batch(\n",
        "            batch_tickets\n",
        "        )\n",
        "\n",
        "        for ticket_id, result in zip(\n",
        "            batch_ids,\n",
        "            results\n",
        "        ):\n",
        "\n",
        "            predictions.append({\n",
        "\n",
        "                \"ticket_id\": ticket_id,\n",
        "\n",
        "                \"predicted_category\": result[\"category\"],\n",
        "\n",
        "                \"confidence\": result[\"confidence\"],\n",
        "\n",
        "                \"reasoning\": result[\"reasoning\"]\n",
        "\n",
        "            })\n",
        "\n",
        "    except Exception as e:\n",
        "\n",
        "        print(f\"Batch Error: {e}\")\n",
        "\n",
        "        for ticket_id in batch_ids:\n",
        "\n",
        "            predictions.append({\n",
        "\n",
        "                \"ticket_id\": ticket_id,\n",
        "\n",
        "                \"predicted_category\": \"unknown\",\n",
        "\n",
        "                \"confidence\": 0.0,\n",
        "\n",
        "                \"reasoning\": \"classification failure\"\n",
        "\n",
        "            })\n",
        "\n",
        "    # Groq usually very fast\n",
        "    time.sleep(0.5)\n",
        "\n",
        "print(\"\\nBatch Classification Complete ✅\")"
      ]
    },
