        "import json\n",
        "\n",
        "def classify_ticket_batch(ticket_batch):\n",
        "\n",
        "    formatted_tickets = \"\"\n",
        "\n",
        "    for idx, ticket in enumerate(ticket_batch):\n",
        "\n",
        "        formatted_tickets += f\"\"\"\n",
        "Ticket {idx+1}:\n",
        "{ticket}\n",
        "\"\"\"\n",
        "\n",
        "    prompt = f\"\"\"\n",
        "You are a support ticket classifier for PocketToons.\n",
        "\n",
        "Classify EACH ticket into EXACTLY ONE category.\n",
        "\n",
        "Categories:\n",
        "- billing_refund\n",
        "- content_access\n",
        "- technical_bug\n",
        "- account_management\n",
        "- subscription_plan\n",
        "- general_feedback\n",
        "\n",
        "Return ONLY valid JSON array.\n",
        "\n",
        "Format:\n",
        "\n",
        "[\n",
        "  {{\n",
        "    \"category\": \"billing_refund\",\n",
        "    \"confidence\": 0.95,\n",
        "    \"reasoning\": \"short reason\"\n",
        "  }}\n",
        "]\n",
        "\n",
        "Tickets:\n",
        "{formatted_tickets}\n",
        "\"\"\"\n",
        "\n",
        "    response = client.chat.completions.create(\n",
        "\n",
        "        messages=[\n",
        "            {\n",
        "                \"role\": \"user\",\n",
        "                \"content\": prompt\n",
        "            }\n",
        "        ],\n",
        "\n",
        "        model=\"llama-3.3-70b-versatile\",\n",
        "\n",
        "        temperature=0,\n",
        "\n",
        "        max_tokens=1000\n",
        "    )\n",
        "\n",
        "    raw_text = (\n",
        "        response\n",
        "        .choices[0]\n",
        "        .message\n",
        "        .content\n",
        "        .strip()\n",
        "    )\n",
        "\n",
        "    raw_text = raw_text.replace(\n",
        "        \"```json\",\n",
        "        \"\"\n",
        "    ).replace(\n",
        "        \"```\",\n",
        "        \"\"\n",
        "    )\n",
        "\n",
        "    return json.loads(raw_text)"
      ]
    },
