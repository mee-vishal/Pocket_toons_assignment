      "source": [
        "def generate_reply(ticket_text, category):\n",
        "\n",
        "    prompt = f\"\"\"\n",
        "ROLE:\n",
        "You are a real customer support agent for PocketToons,\n",
        "a streaming and PPV platform.\n",
        "\n",
        "TASK:\n",
        "Write a concise support reply to the customer.\n",
        "\n",
        "STYLE RULES:\n",
        "- Sound human and natural\n",
        "- Be specific to the ticket\n",
        "- Keep it under 60 words\n",
        "- Mention ONE concrete next step\n",
        "- Professional but conversational\n",
        "- Avoid robotic corporate phrasing\n",
        "- Avoid excessive apologies\n",
        "\n",
        "DO NOT USE PHRASES LIKE:\n",
        "- \"I apologize for the inconvenience\"\n",
        "- \"I'm here to help\"\n",
        "- \"We will investigate further\"\n",
        "- \"I understand your frustration\"\n",
        "\n",
        "DO:\n",
        "- acknowledge the actual issue\n",
        "- explain what happens next\n",
        "- sound calm and competent\n",
        "\n",
        "DO NOT:\n",
        "- promise refunds\n",
        "- guarantee outcomes\n",
        "- invent policies\n",
        "- invent timelines\n",
        "\n",
        "GOOD EXAMPLES:\n",
        "\n",
        "Ticket:\n",
        "\"I was charged twice for premium\"\n",
        "\n",
        "Reply:\n",
        "\"Thanks for flagging this. We’re reviewing the duplicate charge on your account and our billing team will check the transaction details shortly.\"\n",
        "\n",
        "Ticket:\n",
        "\"Episode 3 is missing from my library\"\n",
        "\n",
        "Reply:\n",
        "\"That episode should normally appear in your library. We’re checking your account access and content entitlement now.\"\n",
        "\n",
        "NOW WRITE A REPLY FOR:\n",
        "\n",
        "Category:\n",
        "{category}\n",
        "\n",
        "Ticket:\n",
        "\"{ticket_text}\"\n",
        "\n",
        "Return ONLY the reply text.\n",
        "\"\"\"\n",
        "\n",
        "    response = client.chat.completions.create(\n",
        "\n",
        "        messages=[\n",
        "            {\n",
        "                \"role\": \"user\",\n",
        "                \"content\": prompt\n",
        "            }\n",
        "        ],\n",
        "\n",
        "        model=\"llama-3.3-70b-versatile\",\n",
        "\n",
        "        temperature=0.2,\n",
        "\n",
        "        max_tokens=100\n",
        "    )\n",
        "\n",
        "    reply = (\n",
        "\n",
        "        response\n",
        "        .choices[0]\n",
        "        .message\n",
        "        .content\n",
        "        .strip()\n",
        "\n",
        "    )\n",
        "\n",
        "    # cleanup accidental quotes\n",
        "    reply = reply.replace('\"', \"\")\n",
        "\n",
        "    return reply"
      ]
    },
