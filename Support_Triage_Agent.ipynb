      "source": [
        "# =========================================================\n",
        "# ESCALATION RULES\n",
        "# =========================================================\n",
        "\n",
        "ESCALATION_KEYWORDS = [\n",
        "\n",
        "    \"hacked\",\n",
        "    \"fraud\",\n",
        "    \"unauthorized\",\n",
        "    \"legal\",\n",
        "    \"lawsuit\",\n",
        "    \"delete my account\",\n",
        "    \"gdpr\",\n",
        "    \"ccpa\",\n",
        "    \"refund immediately\",\n",
        "    \"stolen\",\n",
        "    \"scam\",\n",
        "    \"terrible service\"\n",
        "\n",
        "]\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# ESCALATION FUNCTION\n",
        "# =========================================================\n",
        "\n",
        "def should_escalate(row):\n",
        "\n",
        "    text = str(\n",
        "        row[\"ticket_text\"]\n",
        "    ).lower()\n",
        "\n",
        "    # =====================================\n",
        "    # KEYWORD ESCALATION\n",
        "    # =====================================\n",
        "\n",
        "    for kw in ESCALATION_KEYWORDS:\n",
        "\n",
        "        if kw in text:\n",
        "            return True\n",
        "\n",
        "    # =====================================\n",
        "    # LOW CONFIDENCE ESCALATION\n",
        "    # =====================================\n",
        "\n",
        "    if row[\"confidence\"] < 0.75:\n",
        "        return True\n",
        "\n",
        "    # =====================================\n",
        "    # URGENT PRIORITY ESCALATION\n",
        "    # =====================================\n",
        "\n",
        "    if \"priority\" in df.columns:\n",
        "\n",
        "        if str(\n",
        "            row[\"priority\"]\n",
        "        ).lower() == \"urgent\":\n",
        "\n",
        "            return True\n",
        "\n",
        "    return False\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# APPLY ESCALATION LOGIC\n",
        "# =========================================================\n",
        "\n",
        "df[\"escalate_flag\"] = df.apply(\n",
        "    should_escalate,\n",
        "    axis=1\n",
        ")\n",
        "\n",
        "print(\"\\nEscalation Summary:\\n\")\n",
        "\n",
        "print(\n",
        "    df[\"escalate_flag\"]\n",
        "    .value_counts()\n",
        ")"
      ]
    },
