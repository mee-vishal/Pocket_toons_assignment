      "source": [
        "df[\"suggested_reply\"] = \"\"\n",
        "\n",
        "reply_mask = (\n",
        "\n",
        "    df[\"predicted_category\"].isin(TOP_2)\n",
        "\n",
        "    &\n",
        "\n",
        "    (~df[\"escalate_flag\"])\n",
        "\n",
        ")\n",
        "\n",
        "print(\n",
        "    f\"\\nGenerating replies for \"\n",
        "    f\"{reply_mask.sum()} tickets...\\n\"\n",
        ")\n",
        "\n",
        "for idx, row in tqdm(\n",
        "\n",
        "    df[reply_mask].iterrows(),\n",
        "\n",
        "    total=reply_mask.sum(),\n",
        "\n",
        "    desc=\"Generating Replies\"\n",
        "\n",
        "):\n",
        "\n",
        "    try:\n",
        "\n",
        "        reply = generate_reply(\n",
        "\n",
        "            row[\"ticket_text\"],\n",
        "\n",
        "            row[\"predicted_category\"]\n",
        "\n",
        "        )\n",
        "\n",
        "        df.at[idx, \"suggested_reply\"] = reply\n",
        "\n",
        "    except Exception as e:\n",
        "\n",
        "        print(e)\n",
        "\n",
        "        df.at[idx, \"suggested_reply\"] = (\n",
        "            \"Human review required.\"\n",
        "        )\n",
        "\n",
        "    time.sleep(0.5)\n",
        "\n",
        "print(\"\\nReply Generation Complete ✅\")"
      ]
